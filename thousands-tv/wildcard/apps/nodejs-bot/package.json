{
    "name": "nodejs-bot",
    "version": "1.0.0",
    "description": "",
    "main": "dist/src/index.js",
    "scripts": {
        "registerCommands": "npx ts-node registerCommands.ts",
        "registerCommandsLocal": "npm run registerCommands -- env=local",
        "registerCommandsTest": "npm run registerCommands -- env=test",
        "registerCommandsProd": "npm run registerCommands -- env=prod",
        "prebuild": "npx eslint",
        "build": "tsc",
        "start": "node dist/src/index.js",
        "start:dev": "nodemon ./src/index.ts",
        "reconcileSwagSets": "npx ts-node reconcileSwagSets.ts",
        "dev": "nodemon --exec 'node --inspect --require ts-node/register src/index.ts'",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wildcard-alliance/wildcard-airdrop-bot.git"
    },
    "dependencies": {
        "@discordjs/rest": "^1.1.0",
        "@repo/interfaces": "*",
        "@repo/utils": "*",
        "@repo/schemas": "*",
        "alchemy-sdk": "^3.3.1",
        "async-mutex": "^0.4.0",
        "axios": "^1.6.0",
        "axios-retry": "^3.4.0",
        "body-parser": "^1.20.2",
        "discord.js": "^14.8.0",
        "dotenv": "^16.0.1",
        "ethers": "^5.7.0",
        "express": "^4.18.1",
        "ioredis": "^5.3.2",
        "lodash": "^4.17.21",
        "module-alias": "^2.2.2",
        "mongoose": "^6.11.3",
        "node-cron": "^3.0.3",
        "tweetnacl": "^1.0.3",
        "uuid": "^9.0.1",
        "viem": "^1.0.0",
        "winston": "^3.8.2"
    },
    "devDependencies": {
        "@types/express": "^4.17.13",
        "@types/lodash": "^4.14.195",
        "@types/mocha": "^9.1.1",
        "@types/module-alias": "^2.0.1",
        "@types/node": "^18.7.9",
        "@types/uuid": "^8.3.4",
        "@typescript-eslint/eslint-plugin": "^5.50.0",
        "@typescript-eslint/parser": "^5.50.0",
        "eslint": "^8.33.0",
        "nodemon": "^2.0.19",
        "ts-node": "^10.9.1",
        "typescript": "^5.1.6"
    }
